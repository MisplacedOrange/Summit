# Hack-Canada-2026 Backend — Environment Variables Template
# Copy this file to backend/.env and fill in your values.
# NEVER commit .env to version control.

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite for local dev, or your production database URL
DATABASE_URL=sqlite+aiosqlite:///./summit.db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Auth0 (REQUIRED in production) ──────────────────────────────────────────
AUTH0_DOMAIN=
AUTH0_AUDIENCE=

# ─── App JWT (REQUIRED in production) ────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
APP_JWT_SECRET=

APP_JWT_EXPIRE_HOURS=24

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ─── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# ─── Mapbox ───────────────────────────────────────────────────────────────────
MAPBOX_SECRET_TOKEN=

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Discord Webhook (optional, for request logging) ─────────────────────────
DISCORD_WEBHOOK_URL=

# ─── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=development        # development | production
ALLOWED_ORIGINS=["http://localhost:3000"]