# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/impactmatch

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.impactmatch.ca

# Supabase (used by backend auth endpoints)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend-issued JWT
APP_JWT_SECRET=replace-with-a-long-random-secret
APP_JWT_EXPIRE_HOURS=24

# Gemini
GEMINI_API_KEY=your-gemini-api-key

# Mapbox (for server-side geocoding)
MAPBOX_SECRET_TOKEN=your-mapbox-secret-token

# App
ENVIRONMENT=development
ALLOWED_ORIGINS=["http://localhost:3000"]

# Discord request forwarding
DISCORD_WEBHOOK_URL=
